{
  "manifest_version": 3,
  "name": "Untappd → Obsidian Cellar",
  "version": "1.0.2",
  "description": "Save any Untappd beer page to your Obsidian beer cellar with one click.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["https://untappd.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://untappd.com/b/*", "https://untappd.com/beer/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
